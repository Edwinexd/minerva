DATABASE_URL=postgres://minerva:minerva@localhost:5432/minerva
QDRANT_URL=http://localhost:6334
MINERVA_HOST=0.0.0.0
MINERVA_PORT=3000
MINERVA_DOCS_PATH=./data/documents
MINERVA_HMAC_SECRET=change-this-to-a-random-secret

# Comma-separated eppn usernames (prefix before @) who get admin role
MINERVA_ADMINS=edsu8469

# LLM provider keys. A provider is only available (and its models only
# enableable) when its key is set. CEREBRAS_API_KEY is required; the rest
# are optional. OPENAI_API_KEY also powers OpenAI embeddings.
CEREBRAS_API_KEY=your-cerebras-key
OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key
# GROQ_API_KEY=your-groq-key
# GEMINI_API_KEY=your-gemini-key  # Google, via its OpenAI-compatible endpoint
# Override a provider's base URL for self-hosted / proxy endpoints
# (provider id uppercased), e.g.:
# MINERVA_LLM_BASE_URL__CEREBRAS=https://api.cerebras.ai/v1

# LTI 1.3 RSA key seed (deterministic key derivation). Falls back to HMAC secret if unset.
# MINERVA_LTI_KEY_SEED=your-lti-key-seed

# Public base URL (used for LTI tool URLs). Defaults to https://minerva.dsv.su.se.
# MINERVA_BASE_URL=https://minerva.dsv.su.se

# AI spending caps in USD (both daily, 0 = unlimited). Spend is computed
# from token usage x each model's per-Mtok rate (set per model in
# /admin, with a best-effort "scrape price" helper). These seed the
# admin-tunable system defaults on a fresh install.
# Per-student-per-course default applied at course creation.
# MINERVA_DEFAULT_COURSE_DAILY_USD=0.50
# Per-owner aggregate cap applied to *new* users on first login. Sums across
# every course they own. Existing users keep their value of 0 until an admin
# adjusts via /admin/users.
# MINERVA_DEFAULT_OWNER_DAILY_USD=2.50
