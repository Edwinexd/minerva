# Auto-loaded by direnv on `cd` into the repo.
#
# Points DATABASE_URL at a per-branch postgres DB (see scripts/dev-db.sh)
# so a migration on one branch can't corrupt another branch's state.
# `master` keeps using the existing `minerva` DB; other branches get
# their own `minerva_<slug>` carved off via postgres TEMPLATE copy.
#
# The `ensure` step is best-effort: if the postgres container isn't
# running we still export the URL (so cargo / docker compose pick up
# the right one) and create the DB on the next `dev-db.sh ensure` or
# `docker compose up -d postgres` cycle.
#
# First time: `direnv allow` to authorise this file.

export DATABASE_URL=$(./scripts/dev-db.sh url)
./scripts/dev-db.sh ensure 2>/dev/null || true

# Personal overrides (gitignored) go here.
[ -f .envrc.local ] && source_env .envrc.local
