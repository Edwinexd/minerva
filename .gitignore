# fastembed-rs downloads ONNX weights into this dir at runtime; per-developer
# cache, not a build artifact, and the worker (or seed feature) recreates it
# as needed. Lives under backend/ because that's the cwd the dev server runs
# from.
backend/.fastembed_cache/

# K8s secrets (generated by terraform/deploy workflow)
k8s/overlays/prod/secrets.yaml

