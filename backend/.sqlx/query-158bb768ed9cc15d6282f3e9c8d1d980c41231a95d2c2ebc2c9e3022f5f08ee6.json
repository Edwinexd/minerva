  "db_name": "PostgreSQL",
  "query": "SELECT id, name, issuer, client_id, deployment_id, auth_login_url, auth_token_url, platform_jwks_url, created_by, created_at, updated_at, allowed_eppn_domains, activated_at, last_health_check_at, last_health_check_status, invalid_client_since\n        FROM lti_platforms\n        WHERE activated_at IS NOT NULL\n          AND (last_health_check_at IS NULL\n               OR last_health_check_at < NOW() - make_interval(hours => $1))\n        ORDER BY last_health_check_at NULLS FIRST",
