  "db_name": "PostgreSQL",
  "query": "SELECT\n            b.id AS binding_id,\n            b.platform_id,\n            p.name AS platform_name,\n            p.issuer AS platform_issuer,\n            p.client_id AS platform_client_id,\n            b.context_id,\n            b.context_label,\n            b.context_title,\n            b.course_id,\n            b.created_at\n        FROM lti_course_bindings b\n        JOIN lti_platforms p ON p.id = b.platform_id\n        WHERE b.course_id = $1\n        ORDER BY b.created_at DESC",
