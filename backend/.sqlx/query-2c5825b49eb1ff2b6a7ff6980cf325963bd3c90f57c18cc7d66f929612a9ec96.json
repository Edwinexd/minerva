  "query": "SELECT id, course_id, filename, mime_type, created_at\n           FROM documents\n           WHERE content_hash IS NULL\n             AND orphaned_at IS NULL\n             AND ($1::timestamptz IS NULL OR (created_at, id) > ($1, $2))\n           ORDER BY created_at ASC, id ASC\n           LIMIT $3",
