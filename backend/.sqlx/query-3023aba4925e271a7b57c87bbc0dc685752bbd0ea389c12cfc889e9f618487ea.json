  "query": "\n        INSERT INTO relink_queue (course_id, first_marked_at, due_at)\n        VALUES ($1, NOW(), NOW())\n        ON CONFLICT (course_id) DO UPDATE\n            SET due_at = LEAST(relink_queue.due_at, NOW())\n        RETURNING course_id, first_marked_at, due_at\n        ",
