{
  "db_name": "PostgreSQL",
  "query": "SELECT\n            r.question_id,\n            q.prompt AS question_prompt,\n            q.kind   AS question_kind,\n            q.ord    AS question_ord,\n            r.likert_value,\n            r.free_text_value,\n            r.submitted_at\n        FROM study_survey_responses r\n        JOIN study_survey_questions q ON q.id = r.question_id\n        WHERE r.survey_id = $1 AND r.user_id = $2\n        ORDER BY q.ord ASC",
