{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            a.id, a.message_id, a.suggestions, a.mode, a.model_used, a.created_at\n        FROM prompt_analyses a\n        JOIN messages m ON m.id = a.message_id\n        WHERE m.conversation_id = $1\n        ORDER BY m.created_at ASC, a.created_at ASC\n        ",
