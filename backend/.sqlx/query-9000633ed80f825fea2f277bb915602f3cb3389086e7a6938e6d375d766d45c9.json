  "query": "SELECT pa.message_id, pa.suggestions, pa.mode, pa.model_used, pa.created_at\n        FROM prompt_analyses pa\n        JOIN messages m ON m.id = pa.message_id\n        WHERE m.conversation_id = $1\n        ORDER BY pa.created_at ASC",
