  "query": "SELECT id, course_id, name, canvas_base_url, canvas_api_token, canvas_course_id, auto_sync, created_by, created_at, updated_at, last_synced_at\n        FROM canvas_connections\n        WHERE auto_sync = true\n          AND (last_synced_at IS NULL OR last_synced_at < NOW() - make_interval(hours => $1))\n        ORDER BY last_synced_at NULLS FIRST",
