  "query": "SELECT cm.course_id, cm.user_id, cm.role, cm.added_at, u.eppn AS \"eppn?\", u.display_name\n        FROM course_members cm\n        JOIN users u ON u.id = cm.user_id\n        WHERE cm.course_id = $1\n        ORDER BY cm.added_at",
