# Minimal Dockerfile used by the k3d smoke test only. Copies the
# host-built release binary directly so the test loop doesn't pay the
# multi-minute cargo cold-cache hit inside Docker. Prod builds go
# through Dockerfile.prod (which compiles from source with TARGET_BIN).
#
# Usage:
#   cd backend && cargo build --release -p minerva-embedder
#   docker build -f docker/Dockerfile.embedder-test \
#     -t minerva-embedder:test ../
FROM debian:trixie-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates libssl3 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*
COPY backend/target/release/minerva-embedder /usr/local/bin/minerva-embedder
EXPOSE 50051
CMD ["/usr/local/bin/minerva-embedder"]
