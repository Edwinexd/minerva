FROM node:26-alpine

WORKDIR /app
# .npmrc carries `legacy-peer-deps=true` (jsx-a11y still caps its peer
# at eslint 9). Must land BEFORE `npm ci`, otherwise resolution fails
# with ERESOLVE. Mirrors what Dockerfile.prod already does for the
# same reason ; this dev image was the missing half of that fix.
COPY package.json package-lock.json .npmrc ./
RUN npm ci
COPY . .

EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
