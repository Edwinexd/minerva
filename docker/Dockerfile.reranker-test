# Mirror of Dockerfile.embedder-test for the reranker. See that file's
# header for the rationale.
FROM debian:trixie-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates libssl3 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*
COPY backend/target/release/minerva-reranker /usr/local/bin/minerva-reranker
EXPOSE 50052
CMD ["/usr/local/bin/minerva-reranker"]
