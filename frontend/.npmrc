# eslint-plugin-jsx-a11y (and some other lint plugins) still declare a peer
# range that caps at eslint 9, but they work correctly with eslint 10's flat
# config. Enabling legacy-peer-deps lets `npm install`/`npm ci` resolve the
# tree instead of erroring on that conservative peer range. Remove once the
# plugins publish eslint 10 in their peerDependencies.
legacy-peer-deps=true
