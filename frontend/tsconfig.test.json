{
  // Standalone type-check program for the test suite. It is intentionally NOT
  // part of the `tsc -b` project graph (tsconfig.json references) so the
  // production build stays free of test/vitest types; tsconfig.app.json
  // excludes the test files. Run with `tsc -p tsconfig.test.json` (see the
  // `typecheck:test` npm script) to type-check src + tests together with the
  // vitest/jest-dom globals available.
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "types": ["vite/client", "vitest/globals", "node", "@testing-library/jest-dom"],
    "noEmit": true
  },
  "include": ["src"],
  "exclude": []
}
