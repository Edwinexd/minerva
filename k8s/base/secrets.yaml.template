# Reference template for the k8s secret shape.
# The actual secret is generated by terraform (K8S_SECRETS GitHub secret)
# and applied by the deploy workflow. Do NOT manually create secrets.yaml.
apiVersion: v1
kind: Secret
metadata:
  name: minerva-secrets
  namespace: minerva
type: Opaque
stringData:
  POSTGRES_USER: "minerva"
  POSTGRES_PASSWORD: "CHANGE_ME"
  DATABASE_URL: "postgres://minerva:CHANGE_ME@postgres:5432/minerva"
  MINERVA_HMAC_SECRET: "CHANGE_ME_RANDOM_STRING"
  MINERVA_ADMINS: "edsu8469"
  CEREBRAS_API_KEY: "csk-..."
  OPENAI_API_KEY: "sk-..."
